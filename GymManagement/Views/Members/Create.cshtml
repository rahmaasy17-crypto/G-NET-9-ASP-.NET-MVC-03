@using GymManagement.DAL.Data.Models.Enums
@*which model that i will bind to take values*@
@model CreateMemberViewModel
<div class="container">
    <main role="main" class="pb-3">

        <header class="mb-4">
            <h3 class="text-primary-color">Add Member</h3>
        </header>
        <form asp-controller="Members" asp-action="CreateMember" method="post"> @*الفورم اللي هستقبل جواها الداتا*@

            <!-- Step navigation -->
            <ul class="nav nav-tabs mb-4" id="addMemberTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="member-tab" data-bs-toggle="tab" data-bs-target="#member-info"
                            type="button" role="tab">
                        Member Info
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="health-tab" data-bs-toggle="tab" data-bs-target="#health-info"
                            type="button" role="tab">
                        Health Data
                    </button>
                </li>
            </ul>

            <!-- Tab content -->
            <div class="tab-content">
                <!-- Member Info -->
                <div class="tab-pane fade show active" id="member-info" role="tabpanel" aria-labelledby="member-tab">
                    <div class="section-header mb-3">
                        <h5 class="text-primary fw-bold">Personal Information</h5>
                        <hr class="mt-2">
                    </div>
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" /> @*لما اخده هيبقي اسمه اي ونوعه ايه*@
                        </div>
                        <div class="col-12 col-md-6">
                            <label asp-for="Email" class="form-label">Email</label>
                            <input asp-for="Email" class="form-control" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label asp-for="Phone" class="form-label"></label>
                            <input asp-for ="Phone" class="form-control" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label asp-for="DateOfBirth"  class="form-label"></label>
                            <input asp-for="DateOfBirth" class="form-control" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label asp-for="Gender" class="form-label"></label>
                            <select asp-for ="Gender" class="form-select" asp-items="Html.GetEnumSelectList<Gender>()"> @*هيعممل الليست علي حسبب عدد القيم اللي فال enum*@
                                <option value="">-- Select Gender --</option>
                               
                            </select>
                        </div>
                    </div>
                    <div class="section-header mb-3 mt-4">
                        <h5 class="text-primary fw-bold">Address Information</h5>
                        <hr class="mt-2">
                    </div>
                    <div class="row g-3">

                        <div class="col-12 col-md-6">
                            <label asp-for="BuildingNumber" class="form-label"></label>
                            <input asp-for="BuildingNumber" class="form-control" />
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label">Street</label>
                            <input name="Street" class="form-control" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label asp-for="City"  class="form-label"></label>
                            <input asp-for="City" class="form-control" />
                        </div>
                    </div>
                </div>

                <!-- Health Data -->
                <div class="tab-pane fade" id="health-info" role="tabpanel" aria-labelledby="health-tab">
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label asp-for="HealthRecordViewModel.Height" class="form-label"></label>
                            <input asp-for="HealthRecordViewModel.Height"  class="form-control" />
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="HealthRecordViewModel.Weight" class="form-label"></label>
                            <input asp-for="HealthRecordViewModel.Weight" class="form-control" />
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="HealthRecordViewModel.BloodType" class="form-label"> </label>
                            <select asp-for="HealthRecordViewModel.BloodType" class="form-select">
                                <option value="">Select</option>
                                <option>A+</option>@*لو عملاها شبه الgender هعملها بنفس الطريقه اللي فوق*@
                                <option>A-</option>
                                <option>B+</option>
                                <option>B-</option>
                                <option>O+</option>
                                <option>O-</option>
                                <option>AB+</option>
                                <option>AB-</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6">
                            <label asp-for="HealthRecordViewModel.Note" class="form-label"></label>
                            <input asp-for="HealthRecordViewModel.Note"class="form-control" />
                        </div>
                    </div>
                </div>
            </div>
            
            <footer class="d-flex justify-content-end gap-3 mt-4">
                <a asp-controller="Members" asp-action="Index" class="btn btn-outline-secondary px-4">
                    <i class="bi bi-arrow-left me-2"></i> Back to List
                </a>

                <button type="submit" class="btn btn-primary px-4">  @* Will go to membercontroller>create[http post]*@
                    <i class="bi bi-plus-circle me-2"></i> Add
                </button>
            </footer>

        </form>

    </main>
</div>








